root = true

[*]
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
indent_style = space

[*.{c,cc,cpp,cxx,h,hh,hpp,hxx}]
indent_size = 4
max_line_length = 100

[*.{js,jsx,ts,tsx,mjs,cjs}]
indent_size = 2

[*.{json,yml,yaml,toml}]
indent_size = 2

[*.{html,css}]
indent_size = 2

[*.py]
indent_size = 4

[CMakeLists.txt]
indent_size = 4

[*.cmake]
indent_size = 4

[Makefile]
indent_style = tab

[*.md]
trim_trailing_whitespace = false
