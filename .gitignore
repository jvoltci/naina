!models/registry.yaml
!models/manifest.schema.json

# Datasets (benchmarks)
benchmarks/datasets/data/
benchmarks/results/*.local.json

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*.iml
.DS_Store
Thumbs.db

