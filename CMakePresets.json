{
    "version": 6,
    "cmakeMinimumRequired": { "major": 3, "minor": 24, "patch": 0 },
    "configurePresets": [
        {
            "name": "_base",
            "hidden": true,
            "binaryDir": "${sourceDir}/build/${presetName}",
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "macos-arm64",
            "inherits": "_base",
            "displayName": "macOS arm64 (Apple Silicon)",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_OSX_ARCHITECTURES": "arm64"
            }
        },
        {
            "name": "macos-arm64-debug",
            "inherits": "macos-arm64",
            "displayName": "macOS arm64 Debug",
            "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
        },
        {
            "name": "linux-x86_64",
            "inherits": "_base",
            "displayName": "Linux x86_64",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            },
            "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
        },
        {
            "name": "linux-x86_64-debug",
            "inherits": "linux-x86_64",
            "displayName": "Linux x86_64 Debug",
            "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
        },
        {
            "name": "linux-arm64",
            "inherits": "_base",
            "displayName": "Linux arm64 (cross or native)",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_SYSTEM_PROCESSOR": "aarch64"
            }
        },
        {
            "name": "windows-x86_64",
            "inherits": "_base",
            "displayName": "Windows x86_64 (MSVC)",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            },
            "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
        }
    ],
    "buildPresets": [
        { "name": "macos-arm64",        "configurePreset": "macos-arm64" },
        { "name": "macos-arm64-debug",  "configurePreset": "macos-arm64-debug" },
        { "name": "linux-x86_64",       "configurePreset": "linux-x86_64" },
        { "name": "linux-x86_64-debug", "configurePreset": "linux-x86_64-debug" },
        { "name": "linux-arm64",        "configurePreset": "linux-arm64" },
        { "name": "windows-x86_64",     "configurePreset": "windows-x86_64" }
    ],
    "testPresets": [
        {
            "name": "macos-arm64",
            "configurePreset": "macos-arm64",
            "output": { "outputOnFailure": true }
        },
        {
            "name": "linux-x86_64",
            "configurePreset": "linux-x86_64",
            "output": { "outputOnFailure": true }
        }
    ]
}
